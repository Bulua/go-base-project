COMPOSE_PROJECT_NAME=gobaseproject

# Public ports on the host machine
SERVER_PORT=8080
WEB_PORT=5173
REDIS_PORT=16379
MYSQL_PORT=13307

# App
APP_ENV=development
APP_NAME=GoBaseProject
JWT_SECRET=change-me-in-production

# Database
# Default points to your remote DB host. For local Docker MySQL, set DB_HOST=mysql
# and run: docker compose --profile local-db up -d --build
DB_HOST=localhost
DB_PORT=3306
DB_NAME=go_base_project
DB_USER=root
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

# Local MySQL profile only
MYSQL_ROOT_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT_IN_CONTAINER=6379
REDIS_PASSWORD=change-me
REDIS_DB=0

# Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10
