COMPOSE_PROJECT_NAME=gobaseproject

# Public ports on the host machine
SERVER_PORT=8080
WEB_PORT=5173
REDIS_PORT=16379
MYSQL_PORT=13307

# App
APP_ENV=development
APP_NAME=GoBaseProject
JWT_SECRET=change-me-in-production

# Database
# localhost is for running the Go server directly on the host.
# Full-local Docker start overrides DB_HOST to mysql via docker-compose.local.yaml.
# If the server container connects to a database on the host, use host.docker.internal
# on Docker Desktop instead of localhost.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=go_base_project
DB_USER=root
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

# Local MySQL profile only
MYSQL_ROOT_PASSWORD=change-me

# Redis
# Full-local Docker start overrides REDIS_HOST to redis via docker-compose.local.yaml.
# If the server container connects to Redis on the host, use host.docker.internal
# on Docker Desktop instead of localhost.
REDIS_HOST=localhost
REDIS_PORT_IN_CONTAINER=6379
REDIS_PASSWORD=change-me
REDIS_DB=0

# Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10
